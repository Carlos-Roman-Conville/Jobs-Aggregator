# Copy this file to `.env` and fill in your real secrets before running.

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/job_pipeline
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- Apify (Indeed scraping) ---
APIFY_TOKEN=your_apify_token_here
APIFY_API_TOKEN=
APIFY_KEY=
APIFY_API_KEY=
APIFY_ACTOR_ID=valig~indeed-jobs-scraper

# --- Google Gemini (bootstrap profile, resume tailoring, gaps LLM, career helper, cover letters, package check) ---
# Use GEMINI_API_KEY or GOOGLE_API_KEY (same Google AI Studio key).
# Model resolution: job_pipeline/genai_settings.py — optional GEMINI_MODEL overrides when role-specific vars are unset.
#   GEMINI_RESUME_BOOTSTRAP_MODEL — PDF merge → consolidated_profile
#   GEMINI_RESUME_TAILOR_MODEL — tailored resume JSON / bullets
#   GEMINI_RESUME_GAP_MODEL — optional LLM gap detection (else follows tailor chain)
#   GEMINI_CAREER_MODEL — career_understanding
#   GEMINI_JOB_APPLY_MODEL — cover letters
#   GEMINI_JOB_PACKAGE_CHECK_MODEL — package sanity check
# GEMINI_JOB_SUMMARY_MODEL — Gemini fallback only (queue scoring uses OPENAI_JOB_SUMMARY_MODEL).
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=
# Pro is stricter at honoring 'No exposure' exclusions; cost still pennies at personal-job-search volume.
GEMINI_RESUME_BOOTSTRAP_MODEL=models/gemini-2.5-pro
GEMINI_RESUME_TAILOR_MODEL=models/gemini-2.5-pro
GEMINI_RESUME_GAP_MODEL=
GEMINI_JOB_SUMMARY_MODEL=models/gemini-2.5-flash
GEMINI_SUMMARY_MAX_RETRIES=6
GEMINI_SUMMARY_RETRY_BASE_SEC=6
GEMINI_CAREER_MODEL=models/gemini-2.5-flash
GEMINI_JOB_PACKAGE_CHECK_MODEL=models/gemini-2.5-flash
GEMINI_JOB_APPLY_MODEL=models/gemini-2.5-flash

# --- OpenAI / ChatGPT (primary job-fit summarization) ---
OPENAI_API_KEY=your_openai_api_key_here
CHATGPT_API_KEY=
OPENAI_JOB_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_SUMMARY_MAX_RETRIES=6
OPENAI_SUMMARY_RETRY_BASE_SEC=6

# --- USAJobs API (ingest) ---
USAJOBS_AUTHORIZATION_KEY=
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=job_pipeline@your-email-here.com
USAJOBS_REQUEST_EMAIL=
JOB_PIPELINE_OWNER_EMAIL=

# --- IMAP rejection sync (optional) ---
JOB_PIPELINE_IMAP_HOST=
JOB_PIPELINE_IMAP_USER=
JOB_PIPELINE_IMAP_PASSWORD=
JOB_PIPELINE_IMAP_FOLDER=INBOX
JOB_PIPELINE_IMAP_TLS=true
JOB_PIPELINE_IMAP_PORT=

# --- RenderCV PDF during package build ---
JOB_PIPELINE_RENDERCV_RENDER=
JOB_PIPELINE_OUTPUTS_ROOT=

# --- browser-use gating ---
BROWSER_USE_MAX_RUNS_PER_DAY=5
BROWSER_USE_JOB_APPLY_PROMPT=
JOB_PIPELINE_BROWSER_USE_ALLOW_EXECUTE=
JOB_PIPELINE_BROWSER_USE_STATE_DIR=

# --- Pipeline behavior / paths ---
JOB_PIPELINE_CONFIG=job_pipeline_config.json
JOB_PIPELINE_CAREER_PROFILE=job_pipeline/career_profile.json
JOB_PIPELINE_AUTO_FILTER_LOW_FIT=true
JOB_PIPELINE_SKIP_PACKAGE_LLM_CHECK=

# --- Optional: LinkedIn (Easy Apply Playwright) ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- API server (n8n) ---
N8N_API_KEY=

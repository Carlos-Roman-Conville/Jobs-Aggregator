{
  "manifest_version": 3,
  "name": "Job Pipeline Autofill",
  "version": "1.1.0",
  "description": "One-click job application autofill from your AI job pipeline profile (Chrome).",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "webNavigation"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "Fill job application",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["fill_engine.js", "content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
